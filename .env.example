# =========================================================================
# Levato — variáveis de ambiente
# Copie este arquivo para ".env.local" (git ignora) para testar localmente,
# e no deploy defina os mesmos valores no Vercel:
#   Settings → Environment Variables
#
# Importante: no Vite só variáveis com prefixo VITE_ chegam ao frontend.
# NÃO coloque segredos de servidor aqui (chave secreta de gateway, etc.) —
# tudo aqui vira público no navegador. Isto é só para IDs/config de frontend.
# =========================================================================

# --- WhatsApp (botão flutuante + rodapé) ---
# Número em formato internacional, só dígitos (55 + DDD + número)
VITE_WHATSAPP_NUMBER=5511999998888
# Como o número aparece escrito no rodapé
VITE_WHATSAPP_DISPLAY=(11) 99999-8888

# --- Contato ---
VITE_CONTACT_EMAIL=contato@levato.com.br

# --- Google Analytics 4 ---
# Pegue em analytics.google.com → Admin → Fluxos de dados → ID de medição
VITE_GA4_ID=G-XXXXXXXXXX

# --- Meta (Facebook) Pixel ---
# Pegue no Gerenciador de Eventos da Meta → seu Pixel → ID
VITE_META_PIXEL_ID=123456789012345

# --- Loja ---
# Valor mínimo em reais para frete grátis
VITE_FREE_SHIPPING_THRESHOLD=199

# =========================================================================
# SERVIDOR (função serverless /api/create-payment)
# SEM prefixo VITE_ → NUNCA chega ao navegador. É um SEGREDO.
# Defina no Vercel em Settings → Environment Variables.
# =========================================================================

# Access Token do Mercado Pago (credencial de produção do seu app)
# Pegue em mercadopago.com.br/developers → suas integrações → Credenciais
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxx

# Assinatura secreta do Webhook do Mercado Pago (para validar as notificações)
# Painel → Suas integrações → seu app → Webhooks → "Assinatura secreta"
MERCADO_PAGO_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx
